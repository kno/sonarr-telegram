NODE_ENV=development
PORT=3000
TRUST_PROXY=false
CORS_ORIGIN=*
RATE_LIMIT_PER_MIN=120

# Redis
REDIS_URL=redis://localhost:6379

# MariaDB
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=app
DB_PASSWORD=app
DB_NAME=sonarr_telegram

# Sonarr
# SONARR_URL=http://localhost:8989/api
# SONARR_API_KEY=your-key

# Telegram (GramJS)
# TELEGRAM_API_ID=123456
# TELEGRAM_API_HASH=xxxxxx
# TELEGRAM_ENC_SECRET=change_me_min_16_chars
# TELEGRAM_ALLOWED_CHANNELS=1234567890,987654321
