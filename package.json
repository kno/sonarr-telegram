{
  "name": "sonarr-telegram",
  "version": "0.1.0",
  "private": true,
  "description": "Integración profesional Telegram ↔ Sonarr con Node/TS",
  "license": "MIT",
  "main": "dist/server.js",
  "scripts": {
    "dev": "bun --hot src/server.ts",
    "dev:up": "docker compose up -d redis",
    "dev:down": "docker compose down",
    "dev:redis:logs": "docker compose logs -f redis",
    "dev:all": "bun run dev:up && bun run dev",
    "setup:env": "bun scripts/setup-env.ts",
    "build": "tsc -p tsconfig.json",
    "start": "bun dist/server.js",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "axios-retry": "^4.4.2",
    "bullmq": "^5.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "pino": "^9.4.0",
    "pino-http": "^10.4.0",
    "prom-client": "^15.1.3",
    "telegram": "^2.22.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.12",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typedoc": "^0.26.6",
    "typescript": "^5.5.4"
  }
}
